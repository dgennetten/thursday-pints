# Copy to .env.local (not committed). Used for local dev and for `vite build` / `npm run deploy`.

# --- MySQL-backed API (optional) ---
# The live site uses static /data.json + /breweries.json unless you set this and rebuild.
# Changing the DB password in DreamHost does NOT flip the app to MySQL — only PHP uses that.
# To serve data from MySQL: put the new password in api/config.php on the server, set this to
# your public API base URL, then run `npm run build` and deploy (dist + api).
VITE_API_BASE_URL=https://thursdaypints.com/api

# --- FTP deployment (see scripts/build-and-deploy.js) ---

SFTP_HOST=your-server.dreamhost.com
SFTP_USERNAME=your-dreamhost-user
SFTP_PASSWORD=your-ftp-password

# Path after FTP login. DreamHost often wants the domain folder only, not a full /home/... path.
# Try: thursdaypints.com/   or   /thursdaypints.com/
# If deploy fails with 550, connect with any FTP client, run PWD, then cd into your site folder and use that path.
FTP_REMOTE_PATH=thursdaypints.com/
